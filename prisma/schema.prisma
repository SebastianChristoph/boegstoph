generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ShoppingList {
  id        String         @id @default(cuid())
  name      String
  createdAt DateTime       @default(now())
  items     ShoppingItem[]
}

model ShoppingItem {
  id        String       @id @default(cuid())
  name      String
  checked   Boolean      @default(false)
  category  String?
  sortOrder Int          @default(0)
  listId    String
  list      ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
}

model ItemKnowledge {
  id          String   @id @default(cuid())
  keyword     String   @unique   // normalized: "mango"
  displayName String             // last used: "Mango"
  category    String             // category id
  useCount    Int      @default(1)
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  category    String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
}

model Photo {
  id           String   @id @default(cuid())
  filename     String   @unique
  originalName String
  createdAt    DateTime @default(now())
}

model FoodIdea {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
}

model BirthdayWish {
  id        String   @id @default(cuid())
  person    String
  wish      String
  createdAt DateTime @default(now())
}

model GardenPlant {
  id             String         @id @default(cuid())
  name           String
  variety        String?
  sowingMethod   String         @default("INDOOR")
  weeksIndoor    Int?
  weeksToPike    Int?
  daysToMaturity Int?
  harvestDays    Int?
  openfarmSlug   String?
  openfarmData   Json?
  thumbnailUrl   String?
  notes          String?
  createdAt      DateTime       @default(now())
  seasons        GardenSeason[]
}

model GardenNeighborRule {
  id    String @id @default(cuid())
  nameA String
  nameB String
  type  String // "good" | "bad"
  @@unique([nameA, nameB, type])
}

model GardenBed {
  id        String         @id @default(cuid())
  name      String
  size      String?
  gridCols  Int            @default(10)
  gridRows  Int            @default(8)
  gridCells        String?  // JSON: "[0,1,2,...]" active cell indices; null = full rectangle
  cellSize         Int      @default(20) // cm per cell
  cellAssignments  String?  // JSON: { "2026": { "cellIndex": "plantId" } }
  createdAt DateTime       @default(now())
  seasons   GardenSeason[]
}

model GardenSeason {
  id             String        @id @default(cuid())
  year           Int
  plantId        String
  plant          GardenPlant   @relation(fields: [plantId], references: [id], onDelete: Cascade)
  bedId          String?
  bed            GardenBed?    @relation(fields: [bedId], references: [id])
  weeksIndoor    Int?
  weeksToPike    Int?
  daysToMaturity Int?
  harvestDays    Int?
  createdAt      DateTime      @default(now())
  todos          GardenTodo[]
  diary          GardenDiary[]
}

model GardenTodo {
  id        String        @id @default(cuid())
  seasonId  String?
  season    GardenSeason? @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  title     String
  dueDate   DateTime?
  done      Boolean       @default(false)
  type      String?
  createdAt DateTime      @default(now())
}

model GardenDiary {
  id        String       @id @default(cuid())
  seasonId  String
  season    GardenSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  note      String
  success   Boolean?
  createdAt DateTime     @default(now())
}

model GardenNote {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
